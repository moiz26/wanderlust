<!DOCTYPE html>
<% layout("/layouts/boilerplate")%>
<body>
    <div class="row mt-3">
        <div class="col-8 offset-2">
            <h3>Create a New listing</h3>
            <form method="post" action="/listings">
                <div class="mb-3">
                    <label for="title" class="form-label">Title</label>
                    <input name="listing[title]" placeholder="Enter title" type="text" class="form-control">
                </div>

                <div class="mb-3">
                    <label for="description" class="form-label">Description</label>
                    <textarea name="listing[description]"  type="text" class="form-control"></textarea><br>
                </div>
                
                <div class="mb-3">
                    <label for="image" class="form-label">Image</label>
                    <input name="listing[image]" placeholder="Enter image URL/link" type="text" class="form-control">
                </div>
                
                <div class="row">
                    <div class="mb-3 col-md-4">
                        <label for="Price" class="form-label">Price</label>
                        <input name="listing[price]" placeholder="Enter price" type="number" class="form-control">
                    </div>

                    <div class="mb-3 col-md-8">
                        <label for="Country" class="form-label">Country</label>
                        <input name="listing[country]" placeholder="Enter conuntry name" type="text" class="form-control">
                    </div>
                </div>
                
                
                <div class="mb-3">
                    <label for="Location" class="form-label">Location</label>
                    <input name="listing[location]" placeholder="Enter location" type="text" class="form-control">
                </div>
                
                <button class="btn btn-dark add-btn mt-3">Add Listing</button> <br> <br>
            </form>
        </div>
    </div>
    
</body>