<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WanderLust</title>
</head>
<body>
    <h2>All listings</h2>
    <form method="GEt" action="/listings/new"> 
        <button>Create</button>
    </form>
    <ul>
        <% for (let listing of allListings) { %>
            <li>
                <a href="/listings/<%= listing._id %>"> <%= listing.title %> </a> <!-- href shows the specific listing based on the id -->
        <% } %>
    </ul>
</body>
</html>